{
  "name": "capacitor-app",
  "version": "1.0.0",
  "description": "An Amazing Capacitor App",
  "type": "module",
  "keywords": [
    "capacitor",
    "mobile"
  ],
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:plugin": "cd .. && npm run build",
    "sync": "npx cap sync",
    "build:ios": "npm run build && npx cap sync ios",
    "build:android": "npm run build && npx cap sync android",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android",
    "ios": "npm run build:plugin && npm run build:ios && npx cap run ios",
    "android": "npm run build:plugin && npm run build:android && npx cap run android",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/core": "latest",
    "@atomicfi/transact-capacitor": "file:..",
    "@capacitor/ios": "8.0.0",
    "@capacitor/android": "8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "latest",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  },
  "author": "",
  "license": "ISC"
}